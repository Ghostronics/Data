# Token del bot de Telegram
# Obtenlo hablando con @BotFather en Telegram → /newbot
TELEGRAM_TOKEN=your_telegram_bot_token_here

# API Key de Anthropic (Claude)
# Obtenla en: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# (Opcional) IDs de Telegram autorizados, separados por coma.
# Déjalo vacío para permitir cualquier usuario.
# Para obtener tu ID: habla con @userinfobot en Telegram.
ALLOWED_USER_IDS=123456789,987654321
